---
import '../styles/global.css';
interface Props {
  title: string;
}
const { title } = Astro.props;
---
<!doctype html>
<html lang="de" class="h-full">
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <meta name="theme-color" content="#166534" />
    <link rel="manifest" href="/manifest.json" />
    <link rel="icon" type="image/svg+xml" href="/favicon.svg" />
    <title>{title}</title>
  </head>
  <body class="h-full bg-stone-50 text-stone-800 antialiased">
    <header class="sticky top-0 z-50 bg-green-900 shadow-lg">
      <nav class="mx-auto flex max-w-6xl items-center justify-between px-4 py-3 sm:px-6">
        <a href="/" class="flex items-center gap-2 text-lg font-bold tracking-tight text-white">
          <svg class="h-7 w-7" viewBox="0 0 32 32" fill="none"><circle cx="16" cy="16" r="14" fill="#22c55e" opacity="0.3"/><path d="M16 4c0 8-6 12-6 18h12c0-6-6-10-6-18z" fill="#22c55e"/><path d="M16 10c0 5 4 8 4 12h-8c0-4 4-7 4-12z" fill="#16a34a"/></svg>
          Guild Designer
        </a>
        <div class="flex items-center gap-1">
          <a href="/" class="rounded-lg px-3 py-1.5 text-sm font-medium text-green-100 transition hover:bg-green-800 hover:text-white">Pflanzen</a>
          <a href="/cards" class="rounded-lg px-3 py-1.5 text-sm font-medium text-green-100 transition hover:bg-green-800 hover:text-white">Karten</a>
        </div>
      </nav>
    </header>
    <main class="mx-auto max-w-6xl px-4 py-6 sm:px-6">
      <slot />
    </main>
    <script>
      if ('serviceWorker' in navigator) {
        navigator.serviceWorker.register('/sw.js');
      }
    </script>
  </body>
</html>
