---
import '../styles/global.css';
interface Props {
  title: string;
}
const { title } = Astro.props;
---
<!doctype html>
<html lang="de" class="h-full">
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <meta name="theme-color" content="#166534" />
    <link rel="manifest" href="/manifest.json" />
    <link rel="icon" type="image/svg+xml" href="/favicon.svg" />
    <title>{title}</title>
    <!-- Plausible Analytics (cookieless, no personal data, EU-hosted).
         Auto-skipped on localhost by Plausible itself.
         ┌─────────────────────────────────────────────────────────────────┐
         │  CHANGE data-domain BELOW WHEN SWITCHING TO A CUSTOM DOMAIN.    │
         │  Then register the new domain in the Plausible dashboard at     │
         │  https://plausible.io/sites — otherwise events are not counted. │
         └─────────────────────────────────────────────────────────────────┘ -->
    <script defer data-domain="permaculture-guild-designer.netlify.app" src="https://plausible.io/js/script.js"></script>
    <script is:inline>
      // Apply theme before paint to avoid a flash of light UI in dark mode.
      (function () {
        try {
          const stored = localStorage.getItem('theme');
          const prefersDark = window.matchMedia('(prefers-color-scheme: dark)').matches;
          const isDark = stored === 'dark' || (!stored && prefersDark);
          document.documentElement.classList.toggle('dark', isDark);
        } catch (_) {}
      })();
    </script>
  </head>
  <body class="flex min-h-full flex-col bg-stone-50 dark:bg-stone-950 text-stone-800 dark:text-stone-100 antialiased">
    <!-- Android / Chrome install banner (top of page, non-sticky) -->
    <div id="install-banner" hidden class="flex items-center justify-between gap-3 bg-green-700 px-4 py-2 text-sm text-white sm:px-6">
      <span class="flex items-center gap-2">
        <svg class="h-4 w-4 shrink-0" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2"><path stroke-linecap="round" stroke-linejoin="round" d="M12 4v12m0 0l-4-4m4 4l4-4M4 20h16"/></svg>
        Perma Guild Forge auf den Startbildschirm legen?
      </span>
      <div class="flex items-center gap-2">
        <button id="install-accept" type="button" class="rounded-md bg-white px-3 py-1 text-xs font-semibold text-green-800 transition hover:bg-stone-100">Installieren</button>
        <button id="install-dismiss" type="button" aria-label="Schließen" class="text-lg leading-none text-white/80 transition hover:text-white">×</button>
      </div>
    </div>
    <header class="sticky top-0 z-50 bg-green-900 dark:bg-green-950 shadow-lg">
      <nav class="mx-auto flex max-w-6xl items-center gap-2 px-4 py-3 sm:px-6">
        <a href="/" class="flex shrink-0 items-center gap-2 text-lg font-bold tracking-tight text-white">
          <svg class="h-7 w-7" viewBox="0 0 32 32" xmlns="http://www.w3.org/2000/svg">
            <polyline points="16,11 20.1,14 16,19.2 9.7,14 16,6.6 24.5,14 16,23.6 16,27"
              fill="none" stroke="white" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round"/>
            <circle cx="16" cy="11" r="1.2" fill="white"/>
          </svg>
          <span class="hidden sm:inline">Perma Guild Forge</span>
        </a>
        <div class="ml-3 flex items-center gap-1 text-sm font-medium">
          <a href="/" data-nav="/" class="rounded-md px-2.5 py-1 text-green-100 transition hover:bg-green-800 hover:text-white dark:hover:bg-green-900">Pflanzen</a>
          <a href="/gilden" data-nav="/gilden" class="rounded-md px-2.5 py-1 text-green-100 transition hover:bg-green-800 hover:text-white dark:hover:bg-green-900">Gilden</a>
        </div>
        <span id="plant-count" class="hidden rounded-full bg-white/15 px-2.5 py-0.5 text-xs font-semibold text-white ring-1 ring-white/30"></span>
        <div class="ml-auto flex items-center gap-1">
          <button id="theme-toggle" type="button" aria-label="Theme umschalten" title="Theme: Automatisch (OS)" class="rounded-lg px-3 py-1.5 text-sm font-medium text-green-100 transition hover:bg-green-800 hover:text-white dark:hover:bg-green-900">
            <!-- 3-state: Auto (monitor) → Hell (sun) → Dunkel (moon) → Auto … -->
            <svg id="theme-icon-auto" class="h-4 w-4" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2"><rect x="3" y="4" width="18" height="12" rx="1.5"/><path stroke-linecap="round" d="M8 20h8M12 16v4"/></svg>
            <svg id="theme-icon-light" class="h-4 w-4 hidden" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2"><circle cx="12" cy="12" r="4"/><path stroke-linecap="round" d="M12 2v2M12 20v2M4.93 4.93l1.41 1.41M17.66 17.66l1.41 1.41M2 12h2M20 12h2M4.93 19.07l1.41-1.41M17.66 6.34l1.41-1.41"/></svg>
            <svg id="theme-icon-dark" class="h-4 w-4 hidden" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2"><path stroke-linecap="round" stroke-linejoin="round" d="M21 12.79A9 9 0 1 1 11.21 3 7 7 0 0 0 21 12.79z"/></svg>
          </button>
          <a href="/settings" class="rounded-lg px-3 py-1.5 text-sm font-medium text-green-100 transition hover:bg-green-800 hover:text-white dark:hover:bg-green-900">
            <svg class="h-4 w-4" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2"><path stroke-linecap="round" stroke-linejoin="round" d="M10.325 4.317c.426-1.756 2.924-1.756 3.35 0a1.724 1.724 0 002.573 1.066c1.543-.94 3.31.826 2.37 2.37a1.724 1.724 0 001.066 2.573c1.756.426 1.756 2.924 0 3.35a1.724 1.724 0 00-1.066 2.573c.94 1.543-.826 3.31-2.37 2.37a1.724 1.724 0 00-2.573 1.066c-.426 1.756-2.924 1.756-3.35 0a1.724 1.724 0 00-2.573-1.066c-1.543.94-3.31-.826-2.37-2.37a1.724 1.724 0 00-1.066-2.573c-1.756-.426-1.756-2.924 0-3.35a1.724 1.724 0 001.066-2.573c-.94-1.543.826-3.31 2.37-2.37.996.608 2.296.07 2.572-1.065z"/><circle cx="12" cy="12" r="3"/></svg>
          </a>
        </div>
      </nav>
    </header>
    <main class="mx-auto w-full max-w-6xl flex-1 px-4 py-6 sm:px-6">
      <slot />
    </main>

    <footer class="border-t border-stone-200 dark:border-stone-800 bg-stone-50 dark:bg-stone-950 py-4 text-sm text-stone-500 dark:text-stone-400">
      <div class="mx-auto flex max-w-6xl flex-wrap items-center justify-between gap-2 px-4 sm:px-6">
        <span>© 2026 Perma Guild Forge</span>
        <nav class="flex flex-wrap gap-4">
          <a href="/hilfe" class="hover:text-stone-700 dark:hover:text-stone-200 hover:underline">Hilfe</a>
          <a href="/datenschutz" class="hover:text-stone-700 dark:hover:text-stone-200 hover:underline">Datenschutz</a>
          <a href="/impressum" class="hover:text-stone-700 dark:hover:text-stone-200 hover:underline">Impressum</a>
        </nav>
      </div>
    </footer>

    <!-- Tastatur-Shortcut-Cheatsheet (öffnet mit ?) -->
    <dialog id="shortcuts-modal" class="m-auto w-full max-w-md rounded-2xl bg-white dark:bg-stone-900 text-stone-800 dark:text-stone-100 p-0 shadow-2xl backdrop:bg-black/40">
      <div class="p-6">
        <div class="mb-3 flex items-center justify-between">
          <h2 class="text-lg font-bold">Tastatur-Shortcuts</h2>
          <button id="shortcuts-close" type="button" aria-label="Schließen" class="text-2xl leading-none text-stone-400 hover:text-stone-700 dark:hover:text-stone-200">×</button>
        </div>
        <table class="w-full text-sm">
          <tbody class="divide-y divide-stone-200 dark:divide-stone-700">
            <tr><td class="py-1.5 pr-4"><kbd class="rounded bg-stone-200 dark:bg-stone-700 px-1.5 py-0.5 text-xs font-mono">?</kbd></td><td>Diese Übersicht</td></tr>
            <tr><td class="py-1.5 pr-4"><kbd class="rounded bg-stone-200 dark:bg-stone-700 px-1.5 py-0.5 text-xs font-mono">/</kbd></td><td>Suche fokussieren</td></tr>
            <tr><td class="py-1.5 pr-4"><kbd class="rounded bg-stone-200 dark:bg-stone-700 px-1.5 py-0.5 text-xs font-mono">Esc</kbd></td><td>Offenen Dialog schließen</td></tr>
            <tr><td class="py-1.5 pr-4"><kbd class="rounded bg-stone-200 dark:bg-stone-700 px-1.5 py-0.5 text-xs font-mono">n</kbd></td><td>Neue Pflanze</td></tr>
            <tr><td class="py-1.5 pr-4"><kbd class="rounded bg-stone-200 dark:bg-stone-700 px-1.5 py-0.5 text-xs font-mono">g</kbd> / <kbd class="rounded bg-stone-200 dark:bg-stone-700 px-1.5 py-0.5 text-xs font-mono">l</kbd> / <kbd class="rounded bg-stone-200 dark:bg-stone-700 px-1.5 py-0.5 text-xs font-mono">c</kbd></td><td>Kacheln / Liste / Karten</td></tr>
            <tr><td class="py-1.5 pr-4"><kbd class="rounded bg-stone-200 dark:bg-stone-700 px-1.5 py-0.5 text-xs font-mono">Shift</kbd>+Klick</td><td>Bereich von letzter bis aktueller Checkbox auswählen</td></tr>
          </tbody>
        </table>
        <p class="mt-4 text-xs text-stone-500 dark:text-stone-400">Shortcuts greifen außerhalb von Eingabefeldern. <kbd class="rounded bg-stone-200 dark:bg-stone-700 px-1 text-[10px] font-mono">Esc</kbd> wirkt überall.</p>
      </div>
    </dialog>

    <!-- iOS Safari install popup (no beforeinstallprompt API on iOS) -->
    <div id="ios-install-popup" hidden class="fixed bottom-4 left-4 right-4 z-50 mx-auto max-w-md rounded-xl bg-white dark:bg-stone-900 p-4 shadow-2xl ring-1 ring-stone-200 dark:ring-stone-700">
      <div class="flex items-start gap-3">
        <div class="shrink-0 text-2xl">📲</div>
        <div class="flex-1 text-sm">
          <p class="font-semibold text-stone-900 dark:text-stone-100">App auf den Startbildschirm</p>
          <p class="mt-1 text-stone-600 dark:text-stone-300">
            Tippe unten in Safari auf
            <svg class="inline h-4 w-4 align-text-bottom" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2"><path stroke-linecap="round" stroke-linejoin="round" d="M4 12v8a2 2 0 002 2h12a2 2 0 002-2v-8M16 6l-4-4m0 0L8 6m4-4v12"/></svg>
            <strong>Teilen</strong> und dann auf
            <strong>„Zum Home-Bildschirm"</strong>.
          </p>
        </div>
        <button id="ios-install-dismiss" type="button" aria-label="Schließen" class="text-stone-400 hover:text-stone-600 dark:hover:text-stone-200">×</button>
      </div>
    </div>

    <script>
      if ('serviceWorker' in navigator) {
        navigator.serviceWorker.register('/sw.js');
      }

      // Highlight active top-nav link based on the current pathname.
      (function () {
        const path = location.pathname.replace(/\/$/, '') || '/';
        document.querySelectorAll<HTMLAnchorElement>('a[data-nav]').forEach(a => {
          if (a.dataset.nav === path) a.classList.add('bg-green-800', 'dark:bg-green-900', 'text-white');
        });
      })();
      // ── 3-state theme toggle: Auto (OS) → Hell → Dunkel → Auto … ─────────
      const themeBtn = document.getElementById('theme-toggle');
      const iconAuto = document.getElementById('theme-icon-auto');
      const iconLight = document.getElementById('theme-icon-light');
      const iconDark = document.getElementById('theme-icon-dark');

      const readTheme = (): 'auto' | 'light' | 'dark' => {
        try { const v = localStorage.getItem('theme'); return v === 'light' || v === 'dark' ? v : 'auto'; }
        catch { return 'auto'; }
      };
      const applyThemeClass = (t: 'auto' | 'light' | 'dark') => {
        const isDark = t === 'dark'
          || (t === 'auto' && window.matchMedia('(prefers-color-scheme: dark)').matches);
        document.documentElement.classList.toggle('dark', isDark);
      };
      const syncThemeIcon = (t: 'auto' | 'light' | 'dark') => {
        iconAuto?.classList.toggle('hidden', t !== 'auto');
        iconLight?.classList.toggle('hidden', t !== 'light');
        iconDark?.classList.toggle('hidden', t !== 'dark');
        themeBtn?.setAttribute('title',
          t === 'auto' ? 'Theme: Automatisch (OS)' : t === 'light' ? 'Theme: Hell' : 'Theme: Dunkel');
      };
      const setTheme = (t: 'auto' | 'light' | 'dark') => {
        try {
          if (t === 'auto') localStorage.removeItem('theme');
          else localStorage.setItem('theme', t);
        } catch {}
        applyThemeClass(t);
        syncThemeIcon(t);
      };
      syncThemeIcon(readTheme());
      themeBtn?.addEventListener('click', () => {
        const cur = readTheme();
        setTheme(cur === 'auto' ? 'light' : cur === 'light' ? 'dark' : 'auto');
      });

      // ── Shortcut-Cheatsheet (?, Esc, Klick auf Backdrop) ─────────────────
      const shortcutsModal = document.getElementById('shortcuts-modal') as HTMLDialogElement | null;
      document.getElementById('shortcuts-close')?.addEventListener('click', () => shortcutsModal?.close());
      shortcutsModal?.addEventListener('click', (e) => {
        // Click on backdrop (the dialog itself, not its content) closes.
        if (e.target === shortcutsModal) shortcutsModal.close();
      });
      document.addEventListener('keydown', (e) => {
        if (e.key !== '?') return;
        const t = e.target as HTMLElement | null;
        if (t && (t.tagName === 'INPUT' || t.tagName === 'TEXTAREA' || t.tagName === 'SELECT' || t.isContentEditable)) return;
        e.preventDefault();
        if (shortcutsModal?.open) shortcutsModal.close();
        else shortcutsModal?.showModal();
      });

      // ── PWA install prompts ──────────────────────────────────────────────
      const installBanner = document.getElementById('install-banner');
      const installAccept = document.getElementById('install-accept');
      const installDismiss = document.getElementById('install-dismiss');
      const iosPopup = document.getElementById('ios-install-popup');
      const iosDismiss = document.getElementById('ios-install-dismiss');

      const lsGet = (k: string) => { try { return localStorage.getItem(k); } catch { return null; } };
      const lsSet = (k: string, v: string) => { try { localStorage.setItem(k, v); } catch {} };

      let deferredPrompt: any = null;

      window.addEventListener('beforeinstallprompt', (e) => {
        e.preventDefault();
        deferredPrompt = e;
        if (installBanner && !lsGet('install-dismissed')) installBanner.hidden = false;
      });

      installAccept?.addEventListener('click', async () => {
        if (!deferredPrompt) return;
        deferredPrompt.prompt();
        try {
          const { outcome } = await deferredPrompt.userChoice;
          if (outcome === 'dismissed') lsSet('install-dismissed', '1');
        } catch {}
        if (installBanner) installBanner.hidden = true;
        deferredPrompt = null;
      });

      installDismiss?.addEventListener('click', () => {
        if (installBanner) installBanner.hidden = true;
        lsSet('install-dismissed', '1');
      });

      window.addEventListener('appinstalled', () => {
        if (installBanner) installBanner.hidden = true;
        if (iosPopup) iosPopup.hidden = true;
        lsSet('install-dismissed', '1');
        lsSet('ios-install-dismissed', '1');
      });

      // iOS Safari heuristic: Apple devices (UA contains iPad/iPhone/iPod)
      // running Safari, not already in standalone mode, popup not yet dismissed.
      const ua = navigator.userAgent;
      const isIOS = /iPad|iPhone|iPod/.test(ua);
      const standalone = window.matchMedia('(display-mode: standalone)').matches
        || (window.navigator as any).standalone === true;
      if (isIOS && !standalone && !lsGet('ios-install-dismissed') && iosPopup) {
        setTimeout(() => { iosPopup.hidden = false; }, 1500);
      }
      iosDismiss?.addEventListener('click', () => {
        if (iosPopup) iosPopup.hidden = true;
        lsSet('ios-install-dismissed', '1');
      });
    </script>
  </body>
</html>
