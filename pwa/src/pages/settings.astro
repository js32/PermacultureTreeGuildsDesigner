---
import Layout from '../layouts/Layout.astro';
---
<Layout title="Perma Guild Forge — Einstellungen">
  <div class="mb-6">
    <h1 class="text-2xl font-bold text-stone-900 dark:text-stone-100">Einstellungen</h1>
    <p class="mt-1 text-sm text-stone-500 dark:text-stone-400">Datenquellen, Ansicht, Theme und Daten verwalten.</p>
  </div>

  <!-- Datenquellen -->
  <section class="mb-8">
    <h2 class="mb-3 text-lg font-semibold text-stone-800 dark:text-stone-100">Datenquellen</h2>
    <div id="sources-list" class="space-y-4"></div>
  </section>

  <!-- Ansicht -->
  <section class="mb-8 rounded-xl bg-white dark:bg-stone-800 p-5 shadow-sm ring-1 ring-stone-200 dark:ring-stone-700">
    <h2 class="text-lg font-semibold text-stone-800 dark:text-stone-100">Ansicht</h2>
    <p class="mt-1 text-xs text-stone-500 dark:text-stone-400">Welche Ansicht beim App-Start gezeigt wird.</p>
    <div class="mt-4 grid gap-4 sm:grid-cols-2">
      <label class="block text-sm">
        <span class="font-medium text-stone-700 dark:text-stone-200">Standard-Ansicht</span>
        <select id="default-view" class="mt-1 block w-full rounded-md border border-stone-300 dark:border-stone-600 bg-white dark:bg-stone-900 px-2.5 py-1.5 shadow-inner focus:border-green-500 focus:outline-none">
          <option value="grid">Kacheln</option>
          <option value="list">Liste</option>
          <option value="cards">Karten</option>
        </select>
      </label>
      <label class="block text-sm">
        <span class="font-medium text-stone-700 dark:text-stone-200">Standard-Kartenvariante</span>
        <select id="default-card-variant" class="mt-1 block w-full rounded-md border border-stone-300 dark:border-stone-600 bg-white dark:bg-stone-900 px-2.5 py-1.5 shadow-inner focus:border-green-500 focus:outline-none">
          <option value="poly">Pflanzenkarten</option>
          <option value="stripe">Streifenkarten</option>
          <option value="baumscheibe">Baumscheibe</option>
        </select>
      </label>
    </div>
  </section>

  <!-- Theme -->
  <section class="mb-8 rounded-xl bg-white dark:bg-stone-800 p-5 shadow-sm ring-1 ring-stone-200 dark:ring-stone-700">
    <h2 class="text-lg font-semibold text-stone-800 dark:text-stone-100">Theme</h2>
    <p class="mt-1 text-xs text-stone-500 dark:text-stone-400">"Auto" folgt der System­einstellung deines Geräts.</p>
    <div class="mt-3 flex flex-wrap gap-4 text-sm">
      <label class="inline-flex items-center gap-2"><input type="radio" name="theme" value="auto" class="theme-radio accent-green-600" /> Auto</label>
      <label class="inline-flex items-center gap-2"><input type="radio" name="theme" value="light" class="theme-radio accent-green-600" /> Hell</label>
      <label class="inline-flex items-center gap-2"><input type="radio" name="theme" value="dark" class="theme-radio accent-green-600" /> Dunkel</label>
    </div>
  </section>

  <!-- Privatsphäre -->
  <section class="mb-8 rounded-xl bg-white dark:bg-stone-800 p-5 shadow-sm ring-1 ring-stone-200 dark:ring-stone-700">
    <h2 class="text-lg font-semibold text-stone-800 dark:text-stone-100">Privatsphäre</h2>
    <label class="mt-3 inline-flex items-start gap-2 text-sm">
      <input type="checkbox" id="plausible-optout" class="mt-0.5 accent-green-600" />
      <span>
        <span class="font-medium text-stone-700 dark:text-stone-200">Plausible-Reichweitenmessung deaktivieren</span>
        <span class="block text-xs text-stone-500 dark:text-stone-400">Plausible erfasst keine personenbezogenen Daten — falls du trotzdem nicht gezählt werden möchtest, hier den Haken setzen. Details in der <a href="/datenschutz" class="text-green-700 dark:text-green-400 hover:underline">Datenschutzerklärung</a>.</span>
      </span>
    </label>
  </section>

  <div class="mb-12 flex gap-3">
    <button id="btn-save" class="rounded-lg bg-green-700 px-5 py-2 text-sm font-medium text-white shadow transition hover:bg-green-800 active:scale-95">Einstellungen speichern</button>
  </div>

  <!-- Daten -->
  <section class="mb-8 rounded-xl bg-white dark:bg-stone-800 p-5 shadow-sm ring-1 ring-stone-200 dark:ring-stone-700">
    <h2 class="text-lg font-semibold text-stone-800 dark:text-stone-100">Daten</h2>
    <p class="mt-1 text-xs text-stone-500 dark:text-stone-400">Alle Pflanzen­daten leben lokal in deinem Browser (IndexedDB).</p>

    <dl class="mt-4 grid gap-2 text-sm sm:grid-cols-2">
      <div>
        <dt class="text-xs font-medium text-stone-500 dark:text-stone-400">Pflanzen­datensätze</dt>
        <dd id="stats-plants" class="font-mono text-stone-800 dark:text-stone-100">…</dd>
      </div>
      <div>
        <dt class="text-xs font-medium text-stone-500 dark:text-stone-400">Speicherverbrauch</dt>
        <dd id="stats-storage" class="font-mono text-stone-800 dark:text-stone-100">…</dd>
      </div>
    </dl>

    <p id="last-backup-info" class="mt-3 text-xs text-stone-500 dark:text-stone-400"></p>

    <div class="mt-4 flex flex-wrap gap-2">
      <button id="btn-backup" class="rounded-lg bg-stone-100 dark:bg-stone-700 px-3 py-1.5 text-sm font-medium text-stone-700 dark:text-stone-200 ring-1 ring-stone-300 dark:ring-stone-600 hover:bg-stone-200 dark:hover:bg-stone-600">Backup herunterladen (JSON)</button>
      <button id="btn-share-backup" hidden class="rounded-lg bg-stone-100 dark:bg-stone-700 px-3 py-1.5 text-sm font-medium text-stone-700 dark:text-stone-200 ring-1 ring-stone-300 dark:ring-stone-600 hover:bg-stone-200 dark:hover:bg-stone-600">Backup teilen…</button>
      <label class="cursor-pointer rounded-lg bg-stone-100 dark:bg-stone-700 px-3 py-1.5 text-sm font-medium text-stone-700 dark:text-stone-200 ring-1 ring-stone-300 dark:ring-stone-600 hover:bg-stone-200 dark:hover:bg-stone-600">
        Backup einlesen…
        <input type="file" id="restore-input" accept=".json,application/json" class="hidden" />
      </label>
      <button id="btn-reload-master" class="rounded-lg bg-stone-100 dark:bg-stone-700 px-3 py-1.5 text-sm font-medium text-stone-700 dark:text-stone-200 ring-1 ring-stone-300 dark:ring-stone-600 hover:bg-stone-200 dark:hover:bg-stone-600">Golden Master neu laden</button>
    </div>

    <!-- WebDAV-Sync (z.B. eigene Nextcloud) — keine Cloud-Pflicht, optional -->
    <details class="mt-4 rounded-lg border border-stone-200 dark:border-stone-700 p-4">
      <summary class="cursor-pointer text-sm font-semibold text-stone-700 dark:text-stone-200">WebDAV-Sync (optional, z.B. Nextcloud)</summary>
      <p class="mt-2 text-xs text-stone-500 dark:text-stone-400">
        Pusht/zieht das JSON-Backup direkt in deinen WebDAV-Speicher. Zugangsdaten bleiben
        im Browser (<code>localStorage</code>), werden nicht übertragen außer ans angegebene Ziel.
        Dein Server muss <strong>CORS</strong> für die Domain dieser App erlauben — bei Nextcloud
        z.B. via <code>occ config:system:set cors.allowed-domains</code>.
      </p>
      <div class="mt-3 grid gap-3 sm:grid-cols-2">
        <label class="block text-xs sm:col-span-2">
          <span class="font-medium text-stone-500 dark:text-stone-400">Ziel-URL (vollständige Datei-URL)</span>
          <input id="webdav-url" type="url" placeholder="https://cloud.example.com/remote.php/dav/files/USER/permaguild-backup.json" class="mt-1 block w-full rounded-md border border-stone-300 dark:border-stone-600 bg-white dark:bg-stone-900 px-2.5 py-1.5 font-mono text-xs shadow-inner focus:border-green-500 focus:outline-none" />
        </label>
        <label class="block text-xs">
          <span class="font-medium text-stone-500 dark:text-stone-400">Benutzername</span>
          <input id="webdav-user" type="text" autocomplete="off" class="mt-1 block w-full rounded-md border border-stone-300 dark:border-stone-600 bg-white dark:bg-stone-900 px-2.5 py-1.5 text-sm shadow-inner focus:border-green-500 focus:outline-none" />
        </label>
        <label class="block text-xs">
          <span class="font-medium text-stone-500 dark:text-stone-400">Passwort / App-Token</span>
          <input id="webdav-pass" type="password" autocomplete="off" class="mt-1 block w-full rounded-md border border-stone-300 dark:border-stone-600 bg-white dark:bg-stone-900 px-2.5 py-1.5 text-sm shadow-inner focus:border-green-500 focus:outline-none" />
        </label>
      </div>
      <div class="mt-3 flex flex-wrap items-center gap-2">
        <button id="btn-webdav-save-creds" class="rounded-lg bg-stone-100 dark:bg-stone-700 px-3 py-1.5 text-xs font-medium text-stone-700 dark:text-stone-200 ring-1 ring-stone-300 dark:ring-stone-600 hover:bg-stone-200 dark:hover:bg-stone-600">Zugang merken</button>
        <button id="btn-webdav-clear-creds" class="rounded-lg bg-stone-100 dark:bg-stone-700 px-3 py-1.5 text-xs font-medium text-stone-700 dark:text-stone-200 ring-1 ring-stone-300 dark:ring-stone-600 hover:bg-stone-200 dark:hover:bg-stone-600">Zugang vergessen</button>
        <span class="h-4 w-px bg-stone-300 dark:bg-stone-700"></span>
        <button id="btn-webdav-push" class="rounded-lg bg-green-700 px-3 py-1.5 text-xs font-medium text-white shadow hover:bg-green-800">Backup hochladen ↑</button>
        <button id="btn-webdav-pull" class="rounded-lg bg-blue-700 px-3 py-1.5 text-xs font-medium text-white shadow hover:bg-blue-800">Backup abrufen ↓</button>
        <span id="webdav-status" class="text-xs text-stone-500 dark:text-stone-400"></span>
      </div>
    </details>

    <!-- Lokale Datei-Sync (File System Access API, nur Chromium) -->
    <details id="details-fsa" class="mt-4 rounded-lg border border-stone-200 dark:border-stone-700 p-4" hidden>
      <summary class="cursor-pointer text-sm font-semibold text-stone-700 dark:text-stone-200">Lokale Datei-Sync (Chrome / Edge)</summary>
      <p class="mt-2 text-xs text-stone-500 dark:text-stone-400">
        Schreibt das Backup direkt in eine Datei auf deinem Gerät oder liest es von dort.
        Die Datei kannst du z.&nbsp;B. in einem Cloud-Ordner ablegen (iCloud Drive, Dropbox,
        Google Drive Offline-Ordner). Nur in Chromium-basierten Browsern verfügbar.
      </p>
      <div class="mt-3 flex flex-wrap items-center gap-2">
        <button id="btn-fsa-write" class="rounded-lg bg-green-700 px-3 py-1.5 text-xs font-medium text-white shadow hover:bg-green-800">In Datei speichern ↑</button>
        <button id="btn-fsa-read" class="rounded-lg bg-blue-700 px-3 py-1.5 text-xs font-medium text-white shadow hover:bg-blue-800">Aus Datei laden ↓</button>
        <span id="fsa-status" class="text-xs text-stone-500 dark:text-stone-400"></span>
      </div>
    </details>

    <!-- GitHub Gist Sync — geräteübergreifend ohne eigenen Server -->
    <details class="mt-4 rounded-lg border border-stone-200 dark:border-stone-700 p-4">
      <summary class="cursor-pointer text-sm font-semibold text-stone-700 dark:text-stone-200">GitHub Gist Sync (geräteübergreifend)</summary>
      <p class="mt-2 text-xs text-stone-500 dark:text-stone-400">
        Speichert das Backup als privates GitHub Gist. Du brauchst einen GitHub-Account und ein
        <a href="https://github.com/settings/tokens/new?scopes=gist&description=Perma+Guild+Forge" target="_blank" rel="noopener" class="text-green-700 dark:text-green-400 hover:underline">Personal Access Token</a>
        mit dem Scope <code>gist</code>. Beim ersten Hochladen wird ein neues Gist angelegt
        und die ID automatisch gespeichert — danach einfach wieder drücken.
      </p>
      <div class="mt-3 grid gap-3 sm:grid-cols-2">
        <label class="block text-xs">
          <span class="font-medium text-stone-500 dark:text-stone-400">GitHub Token (PAT)</span>
          <input id="gist-token" type="password" autocomplete="off" placeholder="ghp_…" class="mt-1 block w-full rounded-md border border-stone-300 dark:border-stone-600 bg-white dark:bg-stone-900 px-2.5 py-1.5 font-mono text-xs shadow-inner focus:border-green-500 focus:outline-none" />
        </label>
        <label class="block text-xs">
          <span class="font-medium text-stone-500 dark:text-stone-400">Gist-ID (leer = wird beim ersten Upload gesetzt)</span>
          <input id="gist-id" type="text" autocomplete="off" placeholder="automatisch gesetzt" class="mt-1 block w-full rounded-md border border-stone-300 dark:border-stone-600 bg-white dark:bg-stone-900 px-2.5 py-1.5 font-mono text-xs shadow-inner focus:border-green-500 focus:outline-none" />
        </label>
      </div>
      <div class="mt-3 flex flex-wrap items-center gap-2">
        <button id="btn-gist-save-creds" class="rounded-lg bg-stone-100 dark:bg-stone-700 px-3 py-1.5 text-xs font-medium text-stone-700 dark:text-stone-200 ring-1 ring-stone-300 dark:ring-stone-600 hover:bg-stone-200 dark:hover:bg-stone-600">Token merken</button>
        <button id="btn-gist-clear-creds" class="rounded-lg bg-stone-100 dark:bg-stone-700 px-3 py-1.5 text-xs font-medium text-stone-700 dark:text-stone-200 ring-1 ring-stone-300 dark:ring-stone-600 hover:bg-stone-200 dark:hover:bg-stone-600">Token vergessen</button>
        <span class="h-4 w-px bg-stone-300 dark:bg-stone-700"></span>
        <button id="btn-gist-push" class="rounded-lg bg-green-700 px-3 py-1.5 text-xs font-medium text-white shadow hover:bg-green-800">Zu Gist hochladen ↑</button>
        <button id="btn-gist-pull" class="rounded-lg bg-blue-700 px-3 py-1.5 text-xs font-medium text-white shadow hover:bg-blue-800">Von Gist abrufen ↓</button>
        <span id="gist-status" class="text-xs text-stone-500 dark:text-stone-400"></span>
      </div>
    </details>

    <div class="mt-6 rounded-lg border border-red-300 dark:border-red-800 bg-red-50 dark:bg-red-900/20 p-4">
      <h3 class="text-sm font-semibold text-red-800 dark:text-red-200">Danger Zone</h3>
      <p class="mt-1 text-xs text-red-700 dark:text-red-300">Löscht alle Pflanzendatensätze und deine Einstellungen unwiderruflich.</p>
      <button id="btn-clear-all" class="mt-3 rounded-lg bg-red-600 px-3 py-1.5 text-sm font-medium text-white ring-1 ring-red-700 hover:bg-red-700">Alle Daten löschen</button>
    </div>
  </section>

  <div id="toast" class="fixed bottom-6 right-6 hidden rounded-lg bg-green-700 px-4 py-2.5 text-sm font-medium text-white shadow-lg transition"></div>
</Layout>

<script>
  import {
    loadSettings, saveSettings,
    getTheme, setTheme, applyTheme,
    isPlausibleOptedOut, setPlausibleOptOut,
    type AppSettings, type ViewMode, type CardVariant, type ThemePref,
  } from '../lib/settings';
  import { getAllPlants, importPlants, clearAllPlants } from '../lib/db';

  const sourcesList = document.getElementById('sources-list')!;
  const toast = document.getElementById('toast')!;
  const defaultView = document.getElementById('default-view') as HTMLSelectElement;
  const defaultCardVariant = document.getElementById('default-card-variant') as HTMLSelectElement;
  const plausibleOptout = document.getElementById('plausible-optout') as HTMLInputElement;
  const statsPlants = document.getElementById('stats-plants')!;
  const statsStorage = document.getElementById('stats-storage')!;

  let settings: AppSettings;

  function showToast(msg: string) {
    toast.textContent = msg;
    toast.classList.remove('hidden');
    setTimeout(() => toast.classList.add('hidden'), 2000);
  }

  function renderSources() {
    sourcesList.innerHTML = settings.sources.map((src, i) => `
      <div class="rounded-xl bg-white dark:bg-stone-800 p-5 shadow-sm ring-1 ring-stone-200 dark:ring-stone-700">
        <div class="flex items-start justify-between gap-4">
          <div class="min-w-0 flex-1">
            <div class="flex items-center gap-3">
              <label class="relative inline-flex cursor-pointer items-center">
                <input type="checkbox" class="src-enabled peer sr-only" data-idx="${i}" ${src.enabled ? 'checked' : ''} />
                <div class="h-6 w-11 rounded-full bg-stone-300 dark:bg-stone-600 after:absolute after:left-[2px] after:top-[2px] after:h-5 after:w-5 after:rounded-full after:bg-white after:shadow after:transition-all peer-checked:bg-green-600 peer-checked:after:translate-x-full"></div>
              </label>
              <h3 class="text-sm font-bold text-stone-800 dark:text-stone-100">${src.name}</h3>
              ${src.url ? `<a href="${src.url}" target="_blank" rel="noopener" class="text-xs text-stone-400 dark:text-stone-500 hover:text-green-700 hover:underline">${new URL(src.url).hostname}</a>` : ''}
            </div>
            <p class="mt-1 text-xs text-stone-500 dark:text-stone-400">${src.description}</p>
          </div>
        </div>
        ${src.needsApiKey ? `
          <div class="mt-3">
            <label class="block text-xs font-medium text-stone-500 dark:text-stone-400">API Key
              <input type="password" class="src-apikey mt-0.5 block w-full max-w-sm rounded-md border border-stone-300 dark:border-stone-600 bg-white dark:bg-stone-900 px-2.5 py-1.5 text-sm shadow-inner focus:border-green-500 focus:ring-2 focus:ring-green-200 focus:outline-none" data-idx="${i}" value="${src.apiKey}" placeholder="API Key eingeben..." />
            </label>
          </div>
        ` : ''}
        <div class="mt-2 flex gap-2">
          <span class="inline-block rounded-full px-2 py-0.5 text-xs font-medium ${src.id === 'wikidata' ? 'bg-blue-50 dark:bg-blue-900/30 text-blue-700 dark:text-blue-300' : 'bg-amber-50 dark:bg-amber-900/30 text-amber-700 dark:text-amber-200'}">
            ${src.id === 'wikidata' ? 'Direkt (CORS-frei)' : 'Über Proxy (Netlify Function)'}
          </span>
        </div>
      </div>
    `).join('');
  }

  function renderPrefs() {
    defaultView.value = settings.defaultView;
    defaultCardVariant.value = settings.defaultCardVariant;
    const t = getTheme();
    document.querySelectorAll<HTMLInputElement>('.theme-radio').forEach(r => { r.checked = r.value === t; });
    plausibleOptout.checked = isPlausibleOptedOut();
  }

  function fmtBytes(n: number): string {
    if (n < 1024) return `${n} B`;
    if (n < 1024 * 1024) return `${(n / 1024).toFixed(1)} kB`;
    return `${(n / (1024 * 1024)).toFixed(2)} MB`;
  }

  async function renderStats() {
    const plants = await getAllPlants();
    statsPlants.textContent = `${plants.length}`;
    if (navigator.storage?.estimate) {
      try {
        const est = await navigator.storage.estimate();
        const used = est.usage ?? 0;
        const quota = est.quota ?? 0;
        statsStorage.textContent = quota
          ? `${fmtBytes(used)} / ${fmtBytes(quota)}`
          : fmtBytes(used);
      } catch {
        statsStorage.textContent = '—';
      }
    } else {
      statsStorage.textContent = '—';
    }
  }

  // ── Save handler ────────────────────────────────────────────────────────
  document.getElementById('btn-save')!.addEventListener('click', () => {
    document.querySelectorAll('.src-enabled').forEach((cb) => {
      const input = cb as HTMLInputElement;
      const idx = parseInt(input.dataset.idx!);
      settings.sources[idx].enabled = input.checked;
    });
    document.querySelectorAll('.src-apikey').forEach((inp) => {
      const input = inp as HTMLInputElement;
      const idx = parseInt(input.dataset.idx!);
      settings.sources[idx].apiKey = input.value;
    });
    settings.defaultView = defaultView.value as ViewMode;
    settings.defaultCardVariant = defaultCardVariant.value as CardVariant;
    saveSettings(settings);

    const themeChoice = (document.querySelector<HTMLInputElement>('.theme-radio:checked')?.value ?? 'auto') as ThemePref;
    setTheme(themeChoice);
    applyTheme(themeChoice);

    setPlausibleOptOut(plausibleOptout.checked);

    showToast('Einstellungen gespeichert');
  });

  // ── Daten: Backup ───────────────────────────────────────────────────────
  async function buildBackupBlob(): Promise<{ blob: Blob; filename: string }> {
    const plants = await getAllPlants();
    const payload = {
      version: 1,
      exportedAt: new Date().toISOString(),
      settings,
      plants,
    };
    const blob = new Blob([JSON.stringify(payload, null, 2)], { type: 'application/json' });
    const filename = `perma-guild-forge-backup-${new Date().toISOString().slice(0, 10)}.json`;
    return { blob, filename };
  }

  function rememberBackupTaken() {
    try { localStorage.setItem('last-backup-at', new Date().toISOString()); } catch {}
    renderLastBackup();
  }
  function renderLastBackup() {
    const el = document.getElementById('last-backup-info');
    if (!el) return;
    let last: string | null = null;
    try { last = localStorage.getItem('last-backup-at'); } catch {}
    el.textContent = last
      ? `Letztes Backup: ${new Date(last).toLocaleString('de-DE')}`
      : 'Noch kein Backup angelegt.';
  }

  function downloadBackupBlob(blob: Blob, filename: string) {
    const url = URL.createObjectURL(blob);
    const a = document.createElement('a');
    a.href = url; a.download = filename;
    document.body.appendChild(a); a.click(); document.body.removeChild(a);
    URL.revokeObjectURL(url);
  }

  document.getElementById('btn-backup')!.addEventListener('click', async () => {
    const { blob, filename } = await buildBackupBlob();
    downloadBackupBlob(blob, filename);
    rememberBackupTaken();
  });

  // (c) Web Share API — nur einblenden wenn vom Browser unterstützt.
  const shareBtn = document.getElementById('btn-share-backup') as HTMLButtonElement | null;
  if (shareBtn && 'share' in navigator) {
    shareBtn.hidden = false;
    shareBtn.addEventListener('click', async () => {
      const { blob, filename } = await buildBackupBlob();
      const file = new File([blob], filename, { type: 'application/json' });
      try {
        if ((navigator as any).canShare?.({ files: [file] })) {
          await navigator.share({ files: [file], title: 'Perma Guild Forge Backup' });
          rememberBackupTaken();
        } else {
          downloadBackupBlob(blob, filename);
          rememberBackupTaken();
        }
      } catch (err) {
        if ((err as Error).name !== 'AbortError') alert(`Teilen fehlgeschlagen: ${err}`);
      }
    });
  }

  // (d) WebDAV-Sync: PUT/GET direkt gegen die User-URL mit Basic Auth.
  //     Creds bleiben in localStorage. CORS muss am Server erlaubt sein.
  const webdavUrl = document.getElementById('webdav-url') as HTMLInputElement;
  const webdavUser = document.getElementById('webdav-user') as HTMLInputElement;
  const webdavPass = document.getElementById('webdav-pass') as HTMLInputElement;
  const webdavStatus = document.getElementById('webdav-status')!;

  function loadWebdavCreds() {
    try {
      webdavUrl.value = localStorage.getItem('webdav-url') || '';
      webdavUser.value = localStorage.getItem('webdav-user') || '';
      webdavPass.value = localStorage.getItem('webdav-pass') || '';
    } catch {}
  }
  function authHeader(): string {
    const raw = `${webdavUser.value}:${webdavPass.value}`;
    return 'Basic ' + btoa(unescape(encodeURIComponent(raw)));
  }
  function setWebdavStatus(msg: string, kind: 'ok' | 'err' | 'idle' = 'idle') {
    webdavStatus.textContent = msg;
    webdavStatus.className = 'text-xs ' + (
      kind === 'ok'  ? 'text-green-700 dark:text-green-400' :
      kind === 'err' ? 'text-red-700 dark:text-red-400'    :
                       'text-stone-500 dark:text-stone-400');
  }

  document.getElementById('btn-webdav-save-creds')!.addEventListener('click', () => {
    try {
      localStorage.setItem('webdav-url', webdavUrl.value.trim());
      localStorage.setItem('webdav-user', webdavUser.value);
      localStorage.setItem('webdav-pass', webdavPass.value);
      setWebdavStatus('Zugang gemerkt.', 'ok');
    } catch (err) { setWebdavStatus(`Fehler: ${err}`, 'err'); }
  });
  document.getElementById('btn-webdav-clear-creds')!.addEventListener('click', () => {
    try {
      localStorage.removeItem('webdav-url');
      localStorage.removeItem('webdav-user');
      localStorage.removeItem('webdav-pass');
      webdavUrl.value = ''; webdavUser.value = ''; webdavPass.value = '';
      setWebdavStatus('Zugang vergessen.', 'idle');
    } catch {}
  });

  document.getElementById('btn-webdav-push')!.addEventListener('click', async () => {
    if (!webdavUrl.value || !webdavUser.value) { setWebdavStatus('URL und Benutzer fehlen.', 'err'); return; }
    setWebdavStatus('Lade hoch…');
    try {
      const { blob } = await buildBackupBlob();
      const res = await fetch(webdavUrl.value, {
        method: 'PUT',
        headers: { 'Authorization': authHeader(), 'Content-Type': 'application/json' },
        body: blob,
      });
      if (!res.ok) throw new Error(`HTTP ${res.status} ${res.statusText}`);
      rememberBackupTaken();
      setWebdavStatus(`Hochgeladen (${res.status}).`, 'ok');
    } catch (err) {
      const msg = (err as Error).message;
      setWebdavStatus(`Fehler: ${msg}. Prüfe URL, Zugangsdaten und CORS am Server.`, 'err');
    }
  });

  document.getElementById('btn-webdav-pull')!.addEventListener('click', async () => {
    if (!webdavUrl.value || !webdavUser.value) { setWebdavStatus('URL und Benutzer fehlen.', 'err'); return; }
    if (!confirm('Backup vom Server abrufen und lokale Pflanzen + Settings überschreiben?')) return;
    setWebdavStatus('Lade herunter…');
    try {
      const res = await fetch(webdavUrl.value, {
        method: 'GET',
        headers: { 'Authorization': authHeader() },
      });
      if (!res.ok) throw new Error(`HTTP ${res.status} ${res.statusText}`);
      const data = await res.json();
      const restoredPlants = Array.isArray(data) ? data : (data.plants ?? []);
      if (!Array.isArray(restoredPlants)) throw new Error('Ungültiges Backup-Format');
      await importPlants(restoredPlants);
      if (!Array.isArray(data) && data.settings) {
        saveSettings(data.settings);
        settings = loadSettings();
        renderSources(); renderPrefs();
      }
      await renderStats();
      setWebdavStatus(`${restoredPlants.length} Pflanzen wiederhergestellt.`, 'ok');
    } catch (err) {
      const msg = (err as Error).message;
      setWebdavStatus(`Fehler: ${msg}. Prüfe URL, Zugangsdaten und CORS.`, 'err');
    }
  });

  loadWebdavCreds();
  renderLastBackup();

  // ── Daten: Backup einlesen ──────────────────────────────────────────────
  (document.getElementById('restore-input') as HTMLInputElement | null)?.addEventListener('change', async (e) => {
    const input = e.target as HTMLInputElement;
    const file = input.files?.[0];
    if (!file) return;
    try {
      const text = await file.text();
      const data = JSON.parse(text);
      const plants = Array.isArray(data) ? data : (data.plants ?? []);
      if (!Array.isArray(plants) || plants.length === 0) {
        throw new Error('Keine Pflanzen im Backup gefunden');
      }
      const restoreSettings = !Array.isArray(data) && data.settings;
      const msg = restoreSettings
        ? `${plants.length} Pflanzen + Einstellungen aus Backup einlesen? Bestehende Pflanzen mit gleicher ID werden überschrieben.`
        : `${plants.length} Pflanzen aus Backup einlesen? Bestehende Pflanzen mit gleicher ID werden überschrieben.`;
      if (!confirm(msg)) { input.value = ''; return; }
      await importPlants(plants);
      if (restoreSettings) {
        saveSettings(data.settings);
        settings = loadSettings();
        renderSources(); renderPrefs();
      }
      showToast(`${plants.length} Pflanzen wiederhergestellt`);
      await renderStats();
    } catch (err) {
      alert(`Backup-Import fehlgeschlagen: ${err instanceof Error ? err.message : String(err)}`);
    } finally {
      input.value = '';
    }
  });

  // ── Daten: Golden Master neu laden ──────────────────────────────────────
  document.getElementById('btn-reload-master')!.addEventListener('click', async () => {
    if (!confirm('Golden-Master-Pflanzen erneut importieren? Bestehende Pflanzen mit gleicher ID werden überschrieben.')) return;
    try {
      const res = await fetch('/plants-db.json');
      if (!res.ok) throw new Error(`HTTP ${res.status}`);
      const data = await res.json();
      const plants = Array.isArray(data) ? data : (data.plants ?? []);
      await importPlants(plants);
      showToast(`${plants.length} Pflanzen importiert`);
      await renderStats();
    } catch (err) {
      alert(`Import fehlgeschlagen: ${err instanceof Error ? err.message : String(err)}`);
    }
  });

  // ── Daten: Alles löschen ────────────────────────────────────────────────
  document.getElementById('btn-clear-all')!.addEventListener('click', async () => {
    if (!confirm('WIRKLICH alle Pflanzen und Einstellungen löschen? Das kann nicht rückgängig gemacht werden.')) return;
    if (!confirm('Letzte Warnung: alle Daten gehen verloren. Fortfahren?')) return;
    await clearAllPlants();
    try { localStorage.clear(); } catch {}
    location.href = '/';
  });

  // ── File System Access API ──────────────────────────────────────────────
  const fsaDetails = document.getElementById('details-fsa') as HTMLDetailsElement | null;
  const fsaStatus = document.getElementById('fsa-status')!;

  function setFsaStatus(msg: string, kind: 'ok' | 'err' | 'idle' = 'idle') {
    fsaStatus.textContent = msg;
    fsaStatus.className = 'text-xs ' + (
      kind === 'ok'  ? 'text-green-700 dark:text-green-400' :
      kind === 'err' ? 'text-red-700 dark:text-red-400'    :
                       'text-stone-500 dark:text-stone-400');
  }

  if (fsaDetails && 'showSaveFilePicker' in window) {
    fsaDetails.hidden = false;

    document.getElementById('btn-fsa-write')!.addEventListener('click', async () => {
      try {
        const { blob, filename } = await buildBackupBlob();
        const handle = await (window as any).showSaveFilePicker({
          suggestedName: filename,
          types: [{ description: 'JSON-Backup', accept: { 'application/json': ['.json'] } }],
        });
        const writable = await handle.createWritable();
        await writable.write(blob);
        await writable.close();
        rememberBackupTaken();
        setFsaStatus('Gespeichert.', 'ok');
      } catch (err) {
        if ((err as Error).name !== 'AbortError') setFsaStatus(`Fehler: ${err}`, 'err');
      }
    });

    document.getElementById('btn-fsa-read')!.addEventListener('click', async () => {
      try {
        const [handle] = await (window as any).showOpenFilePicker({
          types: [{ description: 'JSON-Backup', accept: { 'application/json': ['.json'] } }],
          multiple: false,
        });
        const file = await handle.getFile();
        const text = await (file as File).text();
        const data = JSON.parse(text);
        const plants = Array.isArray(data) ? data : (data.plants ?? []);
        if (!Array.isArray(plants)) throw new Error('Ungültiges Format');
        if (!confirm(`${plants.length} Pflanzen aus Datei einlesen und bestehende überschreiben?`)) return;
        await importPlants(plants);
        if (!Array.isArray(data) && data.settings) {
          saveSettings(data.settings);
          settings = loadSettings();
          renderSources(); renderPrefs();
        }
        await renderStats();
        setFsaStatus(`${plants.length} Pflanzen wiederhergestellt.`, 'ok');
      } catch (err) {
        if ((err as Error).name !== 'AbortError') setFsaStatus(`Fehler: ${err}`, 'err');
      }
    });
  }

  // ── GitHub Gist Sync ─────────────────────────────────────────────────────
  const gistTokenInput = document.getElementById('gist-token') as HTMLInputElement;
  const gistIdInput = document.getElementById('gist-id') as HTMLInputElement;
  const gistStatus = document.getElementById('gist-status')!;
  const GIST_FILENAME = 'perma-guild-forge-backup.json';

  function setGistStatus(msg: string, kind: 'ok' | 'err' | 'idle' = 'idle') {
    gistStatus.textContent = msg;
    gistStatus.className = 'text-xs ' + (
      kind === 'ok'  ? 'text-green-700 dark:text-green-400' :
      kind === 'err' ? 'text-red-700 dark:text-red-400'    :
                       'text-stone-500 dark:text-stone-400');
  }

  function loadGistCreds() {
    try {
      gistTokenInput.value = localStorage.getItem('gist-token') || '';
      gistIdInput.value = localStorage.getItem('gist-id') || '';
    } catch {}
  }

  document.getElementById('btn-gist-save-creds')!.addEventListener('click', () => {
    try {
      localStorage.setItem('gist-token', gistTokenInput.value.trim());
      localStorage.setItem('gist-id', gistIdInput.value.trim());
      setGistStatus('Token gemerkt.', 'ok');
    } catch (err) { setGistStatus(`Fehler: ${err}`, 'err'); }
  });

  document.getElementById('btn-gist-clear-creds')!.addEventListener('click', () => {
    try {
      localStorage.removeItem('gist-token');
      localStorage.removeItem('gist-id');
      gistTokenInput.value = ''; gistIdInput.value = '';
      setGistStatus('Token vergessen.', 'idle');
    } catch {}
  });

  document.getElementById('btn-gist-push')!.addEventListener('click', async () => {
    const token = gistTokenInput.value.trim();
    if (!token) { setGistStatus('Token fehlt.', 'err'); return; }
    setGistStatus('Lade hoch…');
    try {
      const { blob } = await buildBackupBlob();
      const content = await blob.text();
      const id = gistIdInput.value.trim();
      const res = await fetch(id ? `https://api.github.com/gists/${id}` : 'https://api.github.com/gists', {
        method: id ? 'PATCH' : 'POST',
        headers: {
          'Authorization': `Bearer ${token}`,
          'Content-Type': 'application/json',
          'X-GitHub-Api-Version': '2022-11-28',
        },
        body: JSON.stringify({
          description: 'Perma Guild Forge Backup',
          public: false,
          files: { [GIST_FILENAME]: { content } },
        }),
      });
      if (!res.ok) throw new Error(`GitHub API ${res.status}: ${await res.text()}`);
      const result = await res.json();
      if (!id) {
        gistIdInput.value = result.id;
        try { localStorage.setItem('gist-id', result.id); } catch {}
      }
      rememberBackupTaken();
      setGistStatus(`Hochgeladen — Gist ${String(result.id).slice(0, 8)}…`, 'ok');
    } catch (err) {
      setGistStatus(`Fehler: ${(err as Error).message}`, 'err');
    }
  });

  document.getElementById('btn-gist-pull')!.addEventListener('click', async () => {
    const token = gistTokenInput.value.trim();
    const id = gistIdInput.value.trim();
    if (!token || !id) { setGistStatus('Token und Gist-ID fehlen.', 'err'); return; }
    if (!confirm('Backup von GitHub Gist abrufen und lokale Daten überschreiben?')) return;
    setGistStatus('Lade herunter…');
    try {
      const res = await fetch(`https://api.github.com/gists/${id}`, {
        headers: {
          'Authorization': `Bearer ${token}`,
          'X-GitHub-Api-Version': '2022-11-28',
        },
      });
      if (!res.ok) throw new Error(`GitHub API ${res.status}`);
      const gist = await res.json();
      const raw: string | undefined = gist.files?.[GIST_FILENAME]?.content;
      if (!raw) throw new Error(`Datei "${GIST_FILENAME}" nicht im Gist gefunden`);
      const data = JSON.parse(raw);
      const plants = Array.isArray(data) ? data : (data.plants ?? []);
      if (!Array.isArray(plants)) throw new Error('Ungültiges Backup-Format');
      await importPlants(plants);
      if (!Array.isArray(data) && data.settings) {
        saveSettings(data.settings);
        settings = loadSettings();
        renderSources(); renderPrefs();
      }
      await renderStats();
      setGistStatus(`${plants.length} Pflanzen wiederhergestellt.`, 'ok');
    } catch (err) {
      setGistStatus(`Fehler: ${(err as Error).message}`, 'err');
    }
  });

  loadGistCreds();

  // ── Init ────────────────────────────────────────────────────────────────
  settings = loadSettings();
  renderSources();
  renderPrefs();
  renderStats();
</script>
