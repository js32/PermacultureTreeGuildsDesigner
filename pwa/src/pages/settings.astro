---
import Layout from '../layouts/Layout.astro';
---
<Layout title="Guild Designer — Einstellungen">
  <div class="mb-6">
    <h1 class="text-2xl font-bold text-stone-900">Einstellungen</h1>
    <p class="mt-1 text-sm text-stone-500">Datenquellen für die Pflanzensuche konfigurieren.</p>
  </div>

  <div id="sources-list" class="space-y-4"></div>

  <div class="mt-6 flex gap-3">
    <button id="btn-save" class="rounded-lg bg-green-700 px-5 py-2 text-sm font-medium text-white shadow transition hover:bg-green-800 active:scale-95">Speichern</button>
    <button id="btn-reset" class="rounded-lg bg-stone-100 px-4 py-2 text-sm font-medium text-stone-600 ring-1 ring-stone-300 transition hover:bg-stone-200">Zurücksetzen</button>
  </div>

  <div id="toast" class="fixed bottom-6 right-6 hidden rounded-lg bg-green-700 px-4 py-2.5 text-sm font-medium text-white shadow-lg transition"></div>
</Layout>

<script>
  import { loadSettings, saveSettings, DEFAULT_SOURCES, type AppSettings } from '../lib/settings';

  const listEl = document.getElementById('sources-list')!;
  const toast = document.getElementById('toast')!;
  let settings: AppSettings;

  function showToast(msg: string) {
    toast.textContent = msg;
    toast.classList.remove('hidden');
    setTimeout(() => toast.classList.add('hidden'), 2000);
  }

  function render() {
    settings = loadSettings();
    listEl.innerHTML = settings.sources.map((src, i) => `
      <div class="rounded-xl bg-white p-5 shadow-sm ring-1 ring-stone-200">
        <div class="flex items-start justify-between gap-4">
          <div class="min-w-0 flex-1">
            <div class="flex items-center gap-3">
              <label class="relative inline-flex cursor-pointer items-center">
                <input type="checkbox" class="src-enabled peer sr-only" data-idx="${i}" ${src.enabled ? 'checked' : ''} />
                <div class="h-6 w-11 rounded-full bg-stone-300 after:absolute after:left-[2px] after:top-[2px] after:h-5 after:w-5 after:rounded-full after:bg-white after:shadow after:transition-all peer-checked:bg-green-600 peer-checked:after:translate-x-full"></div>
              </label>
              <h3 class="text-sm font-bold text-stone-800">${src.name}</h3>
              ${src.url ? `<a href="${src.url}" target="_blank" rel="noopener" class="text-xs text-stone-400 hover:text-green-700 hover:underline">${new URL(src.url).hostname}</a>` : ''}
            </div>
            <p class="mt-1 text-xs text-stone-500">${src.description}</p>
          </div>
        </div>
        ${src.needsApiKey ? `
          <div class="mt-3">
            <label class="block text-xs font-medium text-stone-500">API Key
              <input type="password" class="src-apikey mt-0.5 block w-full max-w-sm rounded-md border border-stone-300 px-2.5 py-1.5 text-sm shadow-inner focus:border-green-500 focus:ring-2 focus:ring-green-200 focus:outline-none" data-idx="${i}" value="${src.apiKey}" placeholder="API Key eingeben..." />
            </label>
          </div>
        ` : ''}
        <div class="mt-2 flex gap-2">
          <span class="inline-block rounded-full px-2 py-0.5 text-xs font-medium ${src.id === 'wikidata' ? 'bg-blue-50 text-blue-700' : 'bg-amber-50 text-amber-700'}">
            ${src.id === 'wikidata' ? 'Direkt (CORS-frei)' : 'Über Proxy (Netlify Function)'}
          </span>
        </div>
      </div>
    `).join('');
  }

  document.getElementById('btn-save')!.addEventListener('click', () => {
    document.querySelectorAll('.src-enabled').forEach((cb) => {
      const input = cb as HTMLInputElement;
      const idx = parseInt(input.dataset.idx!);
      settings.sources[idx].enabled = input.checked;
    });
    document.querySelectorAll('.src-apikey').forEach((inp) => {
      const input = inp as HTMLInputElement;
      const idx = parseInt(input.dataset.idx!);
      settings.sources[idx].apiKey = input.value;
    });
    saveSettings(settings);
    showToast('Einstellungen gespeichert');
  });

  document.getElementById('btn-reset')!.addEventListener('click', () => {
    saveSettings({ sources: DEFAULT_SOURCES.map(s => ({ ...s })) });
    render();
    showToast('Auf Standard zurückgesetzt');
  });

  render();
</script>
